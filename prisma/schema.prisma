// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  name            String?
  password        String
  role            UserRole     @default(USER)
  status          String       @default("Active")
  isEmailVerified Boolean      @default(false)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([email])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  domain      String   @unique
  website     String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
  MANAGER
  VENDOR
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Software {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  logo              String?
  website           String?
  
  // Section: Ratings and Reports
  rating            Float?   @default(0)
  reportUrl         String?
  
  // Section: Introduction & Verdict
  introduction      String?  @db.Text
  ourVerdict        String?  @db.Text
  
  // Section: Lists
  keyTakeaways      String[] 
  pros              String[]
  cons              String[]
  
  // Section: Media
  pictures          String[] // Gallery URLs
  
  // Section: Content Parts
  howItWorks        String?  @db.Text
  whoIsItFor        String?  @db.Text
  howItIsDifferent  String?  @db.Text
  sentiments        String?  @db.Text
  
  // Section: Flexible Data (Different for all softwares)
  specifications    Json?    // Key-value pairs like { "Platform": "Windows", "License": "SaaS" }
  faqs              Json?    // Array of { "question": "...", "answer": "..." }
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([slug])
}

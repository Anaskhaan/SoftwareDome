// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  name            String?
  image           String?
  password        String
  role            UserRole     @default(USER)
  status          String       @default("Active")
  isEmailVerified Boolean      @default(false)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  companyName     String?
  companyEmail    String?
  companyAddress  String?
  companyPhone    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  reviews         Review[]
  blogs           Blog[]

  @@index([email])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  domain      String   @unique
  website     String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
}

enum UserRole {
  USER
  ADMIN
  VENDOR
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Software {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  logo              String?
  category          String?
  
  // Section: Ratings and Reports
  rating            Float?   @default(0)
  reportUrl         String?
  
  // Section: Introduction & Verdict
  introduction      String?  @db.Text
  ourVerdict        String?  @db.Text
  
  // Section: Lists
  keyTakeaways      String[] 
  pros              String[]
  cons              String[]
  
  // Section: Media
  pictures          String[] // Gallery URLs
  
  // Section: Content Parts
  howItWorks        String?  @db.Text
  whoIsItFor        String?  @db.Text
  howItIsDifferent  String?  @db.Text
  sentiments        String?  @db.Text
  
  // Section: Flexible Data (Different for all softwares)
  specifications    Json?    // Key-value pairs like { "Platform": "Windows", "License": "SaaS" }
  faqs              Json?    // Array of { "question": "...", "answer": "..." }
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  reviews           Review[]

  @@index([slug])
}

model Review {
  id         String   @id @default(cuid())
  content    String   @db.Text
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  softwareId String
  software   Software @relation(fields: [softwareId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, softwareId])
  @@index([softwareId])
}

model Blog {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String?    @db.Text
  content         String     @db.Text
  coverImage      String?
  images          String[]
  tags            String[]
  status          BlogStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?    @db.Text
  publishedAt     DateTime?
  authorId        String
  author          User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
}
